<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>T1zima — Agente de Contenido</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg-primary: #ffffff;
    --bg-secondary: #f5f5f7;
    --bg-tertiary: #f0f0f2;
    --text-primary: #1d1d1f;
    --text-secondary: #6e6e73;
    --text-tertiary: #a1a1a6;
    --border: rgba(0,0,0,0.1);
    --border-strong: rgba(0,0,0,0.18);
    --success-bg: #e8f9ee;
    --success-text: #1a7f37;
    --radius-md: 8px;
    --radius-lg: 12px;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg-primary: #1c1c1e;
      --bg-secondary: #2c2c2e;
      --bg-tertiary: #111111;
      --text-primary: #f5f5f7;
      --text-secondary: #a1a1a6;
      --text-tertiary: #636366;
      --border: rgba(255,255,255,0.1);
      --border-strong: rgba(255,255,255,0.18);
      --success-bg: #0d2e1a;
      --success-text: #3dd68c;
    }
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif; background: var(--bg-tertiary); color: var(--text-primary); min-height: 100vh; }
  .app { display: grid; grid-template-rows: 56px 1fr; height: 100vh; overflow: hidden; }
  /* Topbar */
  .topbar { background: var(--bg-primary); border-bottom: 0.5px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 24px; }
  .logo { font-size: 17px; font-weight: 500; letter-spacing: -0.5px; display: flex; align-items: center; gap: 8px; }
  .logo-badge { background: var(--text-primary); color: var(--bg-primary); font-size: 10px; font-weight: 500; padding: 2px 7px; border-radius: 4px; letter-spacing: 0.5px; }
  .bench-pill { font-size: 12px; padding: 4px 12px; border-radius: 20px; background: var(--success-bg); color: var(--success-text); font-weight: 500; }
  /* Layout */
  .main { display: grid; grid-template-columns: 220px 1fr 290px; height: calc(100vh - 56px); overflow: hidden; }
  /* Sidebar */
  .sidebar { border-right: 0.5px solid var(--border); background: var(--bg-primary); padding: 16px 0; overflow-y: auto; }
  .sidebar-section { padding: 6px 16px; }
  .sidebar-label { font-size: 10px; font-weight: 500; color: var(--text-tertiary); letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 8px; }
  .sidebar-item { display: flex; align-items: center; gap: 10px; padding: 8px 12px; border-radius: var(--radius-md); cursor: pointer; margin-bottom: 2px; transition: background 0.12s; }
  .sidebar-item:hover { background: var(--bg-secondary); }
  .sidebar-item.active { background: var(--bg-secondary); border: 0.5px solid var(--border-strong); }
  .sidebar-item span { font-size: 13px; color: var(--text-primary); }
  .dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .dot-full { background: #3B82F6; } .dot-video { background: #8B5CF6; } .dot-audio { background: #F59E0B; } .dot-copy { background: #10B981; }
  .sidebar-divider { height: 0.5px; background: var(--border); margin: 10px 16px; }
  /* Center */
  .center { display: flex; flex-direction: column; overflow: hidden; background: var(--bg-tertiary); }
  .center-header { background: var(--bg-primary); border-bottom: 0.5px solid var(--border); padding: 0 24px; display: flex; align-items: flex-end; }
  .mode-tab { font-size: 13px; padding: 14px 18px 12px; cursor: pointer; border-bottom: 2px solid transparent; color: var(--text-secondary); transition: all 0.15s; }
  .mode-tab.active { color: var(--text-primary); border-bottom-color: var(--text-primary); font-weight: 500; }
  .content-area { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 14px; }
  /* Cards */
  .card { background: var(--bg-primary); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 20px; }
  .card-title { font-size: 10px; font-weight: 500; color: var(--text-tertiary); letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 14px; }
  .param-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .param-field { display: flex; flex-direction: column; gap: 5px; }
  .param-field.full { grid-column: 1 / -1; }
  .param-field label { font-size: 11px; color: var(--text-secondary); font-weight: 500; }
  .param-field select, .param-field textarea {
    font-size: 13px; border: 0.5px solid var(--border-strong); border-radius: var(--radius-md);
    padding: 8px 10px; background: var(--bg-primary); color: var(--text-primary);
    font-family: inherit; outline: none; transition: border-color 0.15s;
  }
  .param-field select:focus, .param-field textarea:focus { border-color: var(--text-primary); }
  .param-field textarea { resize: vertical; min-height: 72px; line-height: 1.5; }
  /* Multiplier */
  .mult-row { display: flex; align-items: center; gap: 14px; }
  .mult-row input[type=range] { flex: 1; accent-color: var(--text-primary); }
  .mult-val { font-size: 22px; font-weight: 500; min-width: 28px; }
  /* Generate button */
  .gen-btn {
    width: 100%; padding: 13px; background: var(--text-primary); color: var(--bg-primary);
    border: none; border-radius: var(--radius-lg); font-size: 14px; font-weight: 500;
    cursor: pointer; font-family: inherit; display: flex; align-items: center;
    justify-content: center; gap: 8px; transition: opacity 0.15s;
  }
  .gen-btn:hover { opacity: 0.82; }
  .gen-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  /* Output */
  .output-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
  .output-label { font-size: 12px; font-weight: 500; color: var(--text-secondary); }
  .output-actions { display: flex; gap: 8px; }
  .out-btn {
    font-size: 11px; padding: 5px 12px; border: 0.5px solid var(--border-strong);
    border-radius: 20px; cursor: pointer; background: transparent; color: var(--text-secondary);
    font-family: inherit; transition: background 0.12s;
  }
  .out-btn:hover { background: var(--bg-secondary); }
  .output-body { font-size: 14px; line-height: 1.8; color: var(--text-primary); white-space: pre-wrap; }
  /* Variants */
  .variant-card { border: 0.5px solid var(--border); border-radius: var(--radius-md); padding: 14px; cursor: pointer; margin-bottom: 10px; transition: border-color 0.15s; }
  .variant-card:hover { border-color: var(--border-strong); }
  .variant-card.selected { border: 1.5px solid var(--text-primary); }
  .variant-label { font-size: 10px; font-weight: 500; color: var(--text-tertiary); letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 6px; }
  .variant-hook { font-size: 13px; line-height: 1.5; color: var(--text-primary); margin-bottom: 8px; }
  .variant-sub { font-size: 11px; color: var(--text-tertiary); border-top: 0.5px solid var(--border); padding-top: 6px; }
  /* Right panel */
  .rightpanel { border-left: 0.5px solid var(--border); background: var(--bg-primary); overflow-y: auto; }
  .rp-section { padding: 16px; border-bottom: 0.5px solid var(--border); }
  .rp-title { font-size: 10px; font-weight: 500; color: var(--text-tertiary); letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 12px; }
  /* Timer */
  .timer-num { font-size: 30px; font-weight: 500; letter-spacing: -1.5px; font-variant-numeric: tabular-nums; }
  .timer-sub { font-size: 11px; color: var(--text-tertiary); margin-top: 3px; }
  .timer-btns { display: flex; gap: 8px; margin-top: 10px; }
  .t-btn { font-size: 12px; padding: 6px 14px; border: 0.5px solid var(--border-strong); border-radius: 20px; cursor: pointer; background: transparent; color: var(--text-secondary); font-family: inherit; transition: background 0.12s; }
  .t-btn:hover { background: var(--bg-secondary); }
  .t-btn.primary { background: var(--text-primary); color: var(--bg-primary); border-color: var(--text-primary); }
  .t-btn.primary:hover { opacity: 0.82; }
  /* Metrics */
  .metric-row { display: flex; justify-content: space-between; align-items: center; padding: 3px 0; }
  .m-name { font-size: 12px; color: var(--text-secondary); }
  .m-val { font-size: 12px; font-weight: 500; }
  .m-bar { height: 3px; background: var(--border); border-radius: 2px; margin: 3px 0 10px; }
  .m-fill { height: 3px; border-radius: 2px; background: var(--text-primary); transition: width 0.6s; }
  /* Formula */
  .formula { background: var(--bg-secondary); border-radius: var(--radius-md); padding: 10px 12px; font-size: 12px; color: var(--text-secondary); line-height: 1.7; }
  .fv { color: var(--text-primary); font-weight: 500; }
  /* Tools */
  .tool-row { display: flex; align-items: center; justify-content: space-between; padding: 5px 0; }
  .tool-name { font-size: 12px; }
  .tool-badge { font-size: 10px; padding: 2px 8px; border-radius: 10px; font-weight: 500; }
  .on { background: var(--success-bg); color: var(--success-text); }
  .off { background: var(--bg-secondary); color: var(--text-tertiary); }
  /* History */
  .h-item { padding: 7px 0; border-bottom: 0.5px solid var(--border); }
  .h-item:last-child { border-bottom: none; }
  .h-meta { font-size: 10px; color: var(--text-tertiary); margin-bottom: 2px; }
  .h-text { font-size: 12px; color: var(--text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  /* Spinner */
  @keyframes spin { to { transform: rotate(360deg); } }
  .spinner { width: 14px; height: 14px; border: 2px solid rgba(128,128,128,0.3); border-top-color: var(--bg-primary); border-radius: 50%; animation: spin 0.7s linear infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .pulsing { animation: pulse 1.3s ease-in-out infinite; color: var(--text-tertiary); font-style: italic; }
  .hidden { display: none !important; }
  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; } ::-webkit-scrollbar-track { background: transparent; } ::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 2px; }
</style>
</head>
<body>
<div class="app">

  <!-- Topbar -->
  <div class="topbar">
    <div class="logo">T1zima <span class="logo-badge">MVP v0.1</span></div>
    <span class="bench-pill" id="benchPill">0 variantes generadas</span>
  </div>

  <div class="main">

    <!-- Sidebar -->
    <div class="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-label">Modo</div>
        <div class="sidebar-item active" onclick="setMode('full')" id="mode-full"><div class="dot dot-full"></div><span>Flujo completo</span></div>
        <div class="sidebar-item" onclick="setMode('video')" id="mode-video"><div class="dot dot-video"></div><span>Video / guión</span></div>
        <div class="sidebar-item" onclick="setMode('audio')" id="mode-audio"><div class="dot dot-audio"></div><span>Audio / ElevenLabs</span></div>
        <div class="sidebar-item" onclick="setMode('copy')" id="mode-copy"><div class="dot dot-copy"></div><span>Copy / redes</span></div>
      </div>
      <div class="sidebar-divider"></div>
      <div class="sidebar-section">
        <div class="sidebar-label">Producto T1</div>
        <div class="sidebar-item" onclick="setProduct('tienda')" id="prod-tienda"><span>🛍 T1tienda</span></div>
        <div class="sidebar-item" onclick="setProduct('pagos')" id="prod-pagos"><span>💳 T1pagos</span></div>
        <div class="sidebar-item" onclick="setProduct('envios')" id="prod-envios"><span>📦 T1envíos</span></div>
        <div class="sidebar-item" onclick="setProduct('score')" id="prod-score"><span>🛡 T1score</span></div>
        <div class="sidebar-item" onclick="setProduct('partners')" id="prod-partners"><span>🤝 T1Partners</span></div>
        <div class="sidebar-item" onclick="setProduct('ecosistema')" id="prod-ecosistema"><span>🔵 Ecosistema T1</span></div>
      </div>
      <div class="sidebar-divider"></div>
      <div class="sidebar-section">
        <div class="sidebar-label">Historial sesión</div>
        <div id="historyList"><div style="font-size:12px;color:var(--text-tertiary)">Sin sesiones aún</div></div>
      </div>
    </div>

    <!-- Center -->
    <div class="center">
      <div class="center-header">
        <div class="mode-tab active" onclick="setTab('params')" id="tab-params">Parámetros</div>
        <div class="mode-tab" onclick="setTab('output')" id="tab-output">Output</div>
        <div class="mode-tab" onclick="setTab('variantes')" id="tab-variantes">Variantes</div>
      </div>

      <div class="content-area">

        <!-- PARAMS PANEL -->
        <div id="panel-params">
          <div class="card" style="background:var(--bg-secondary);border:0.5px solid var(--border);">
            <div style="font-size:11px;color:var(--text-tertiary);margin-bottom:4px;">Producto seleccionado</div>
            <div style="font-size:16px;font-weight:500;" id="prodBanner">👈 Elige un producto en el sidebar</div>
          </div>

          <div class="card">
            <div class="card-title">Parámetros de contenido</div>
            <div class="param-grid">
              <div class="param-field">
                <label>Audiencia</label>
                <select id="audiencia">
                  <option>PyME / Emprendedor</option>
                  <option>Operador growth</option>
                  <option>Enterprise</option>
                  <option>Partner / Agencia</option>
                </select>
              </div>
              <div class="param-field">
                <label>Canal</label>
                <select id="canal">
                  <option>Instagram Reels</option>
                  <option>TikTok</option>
                  <option>LinkedIn</option>
                  <option>YouTube Shorts</option>
                  <option>Twitter/X</option>
                  <option>WhatsApp</option>
                </select>
              </div>
              <div class="param-field">
                <label>Formato</label>
                <select id="formato">
                  <option>Video corto (15-60s)</option>
                  <option>Carrusel educativo</option>
                  <option>Post texto</option>
                  <option>Guión narrado</option>
                  <option>Thread</option>
                </select>
              </div>
              <div class="param-field">
                <label>Tono</label>
                <select id="tono">
                  <option>Directo / práctico</option>
                  <option>Ejecutivo / estratégico</option>
                  <option>Simple / accesible</option>
                  <option>Bold / aspiracional</option>
                </select>
              </div>
              <div class="param-field full">
                <label>Ángulo / tema</label>
                <textarea id="angulo" placeholder="Ej: por qué vender solo en marketplace te está costando clientes y datos propios..."></textarea>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="card-title">Multiplicador forzado</div>
            <div class="mult-row">
              <input type="range" min="1" max="10" value="3" step="1" id="multiplier" oninput="updateFormula()">
              <div class="mult-val" id="multVal">3</div>
            </div>
            <div style="font-size:11px;color:var(--text-tertiary);margin-top:6px;">Variantes simultáneas — ángulos distintos, no paráfrasis</div>
          </div>

          <button class="gen-btn" id="genBtn" onclick="generate()">
            <span id="genTxt">Generar contenido</span>
            <div class="spinner hidden" id="genSpin"></div>
          </button>
        </div>

        <!-- OUTPUT PANEL -->
        <div id="panel-output" class="hidden">
          <div class="card">
            <div class="output-header">
              <span class="output-label" id="outLabel">Output</span>
              <div class="output-actions">
                <button class="out-btn" onclick="copyOut()">Copiar</button>
                <button class="out-btn" onclick="setTab('variantes')">Variantes</button>
                <button class="out-btn" onclick="setTab('params')">← Editar</button>
              </div>
            </div>
            <div class="output-body" id="outBody">Genera contenido para ver el output aquí.</div>
          </div>
        </div>

        <!-- VARIANTES PANEL -->
        <div id="panel-variantes" class="hidden">
          <div class="card">
            <div class="output-header">
              <span class="output-label">Variantes generadas</span>
              <span style="font-size:11px;color:var(--text-tertiary)" id="varCount">0 variantes</span>
            </div>
            <div id="varGrid"></div>
          </div>
        </div>

      </div>
    </div>

    <!-- Right Panel -->
    <div class="rightpanel">

      <div class="rp-section">
        <div class="rp-title">Sprint Timer</div>
        <div class="timer-num" id="timerNum">25:00</div>
        <div class="timer-sub" id="timerSub">Jake Knapp — máximo foco</div>
        <div class="timer-btns">
          <button class="t-btn primary" id="timerBtn" onclick="toggleTimer()">Iniciar</button>
          <button class="t-btn" onclick="resetTimer()">Reset</button>
        </div>
      </div>

      <div class="rp-section">
        <div class="rp-title">Fórmula de impacto</div>
        <div class="formula">
          1 idea × <span class="fv" id="fMult">3</span> variantes = <span class="fv" id="fTotal">3</span> piezas/sprint<br>
          Tasa objetivo: 1 / <span id="fDen">3</span> → producción
        </div>
      </div>

      <div class="rp-section">
        <div class="rp-title">Benchmarks</div>
        <div class="metric-row"><span class="m-name">Piezas generadas</span><span class="m-val" id="mPiezas">0</span></div>
        <div class="m-bar"><div class="m-fill" id="bPiezas" style="width:0%"></div></div>
        <div class="metric-row"><span class="m-name">Variantes totales</span><span class="m-val" id="mVars">0</span></div>
        <div class="m-bar"><div class="m-fill" id="bVars" style="width:0%"></div></div>
        <div class="metric-row"><span class="m-name">Sprint activo</span><span class="m-val" id="mTime">0 min</span></div>
        <div class="m-bar"><div class="m-fill" id="bTime" style="width:0%"></div></div>
      </div>

      <div class="rp-section">
        <div class="rp-title">Stack de producción</div>
        <div class="tool-row"><span class="tool-name">ElevenLabs</span><span class="tool-badge on">Activo</span></div>
        <div class="tool-row"><span class="tool-name">Runway</span><span class="tool-badge on">Activo</span></div>
        <div class="tool-row"><span class="tool-name">Higgsfield</span><span class="tool-badge on">Activo</span></div>
        <div class="tool-row"><span class="tool-name">Krea</span><span class="tool-badge on">Activo</span></div>
        <div class="tool-row"><span class="tool-name">Claude / ChatGPT</span><span class="tool-badge on">Activo</span></div>
        <div class="tool-row"><span class="tool-name">Cavalry</span><span class="tool-badge off">Pronto</span></div>
        <div class="tool-row"><span class="tool-name">TouchDesigner</span><span class="tool-badge off">Pronto</span></div>
      </div>

      <div class="rp-section">
        <div class="rp-title">Historial</div>
        <div id="rpHist"><div style="font-size:12px;color:var(--text-tertiary)">Sin sesiones aún</div></div>
      </div>

    </div>
  </div>
</div>

<script>
const PRODUCTS = {
  tienda:     { name:'T1tienda',      emoji:'🛍',  ctx:'T1tienda: tienda online + operación multicanal centralizada. Dolores: inventario fragmentado entre canales, overselling, sin control de marca, cambiar precios en varios lados es caos, sin datos propios del cliente. Métricas clave: conversión, GMV por canal, % ventas canal propio vs marketplace.' },
  pagos:      { name:'T1pagos',       emoji:'💳',  ctx:'T1pagos: cobros tipo Stripe — API, links de pago, suscripciones, MSI, SPEI+tarjetas, liquidación T+1. Dolores: rechazos de pago que matan conversión, cashflow lento, sin meses sin intereses, querer vender por WhatsApp sin montar un ecommerce.' },
  envios:     { name:'T1envíos',      emoji:'📦',  ctx:'T1envíos: cotiza y genera guías multi-paquetería, control de calidad (incidencias/sobrepesos), tracking centralizado. Dolores: operación manual lenta y propensa a error, sin visibilidad del status, sobrepesos que comen margen sin avisar, incidencias sin trazabilidad.' },
  score:      { name:'T1score',       emoji:'🛡',  ctx:'T1score: scoring/decisiones de riesgo en tiempo real. Reduce fraude y contracargos sin bloquear ventas legítimas. Dolores: fraude revisado manualmente, falsos positivos que matan conversión, pérdidas silenciosas por contracargos.' },
  partners:   { name:'T1Partners',    emoji:'🤝',  ctx:'T1Partners: programa para agencias, consultores, resellers que quieren monetizar recomendando T1 con comisiones recurrentes, sin ser developer. Audiencia: partners que buscan ingresos adicionales activando clientes en comercio digital.' },
  ecosistema: { name:'T1 Ecosistema', emoji:'🔵',  ctx:'T1 ecosistema AI-first: T1tienda (vender) + T1pagos (cobrar) + T1envíos (enviar) + T1score (reducir riesgo). El valor real está en la integración end-to-end: menos fragmentación, más operación medible y escalable desde México.' }
};

const BRAND = 'Brand T1: Sharp, práctico, sin hype vacío. Beneficio PRIMERO, descripción después — siempre estilo Apple. Tono: directo, operacional, ambicioso pero creíble. NUNCA empezar con el nombre del producto, SIEMPRE empezar con el dolor o el beneficio del usuario.';

const ANGLES = {
  tienda:'Por qué vender solo en marketplace te está costando clientes, datos y marca propia',
  pagos:'Cómo la liquidación lenta está ahorcando tu cashflow sin que lo notes',
  envios:'Los sobrepesos no detectados que están comiendo tu margen cada semana',
  score:'Cómo detener el fraude sin rechazar ventas legítimas',
  partners:'Cómo ganar comisiones recurrentes vendiendo tecnología de comercio sin ser developer',
  ecosistema:'El stack fragmentado que frena a cada comercio en México'
};

let curMode = 'full', curProd = null, variants = [];
let sPiezas = 0, sVars = 0;
let timerOn = false, timerSec = 1500, timerIv = null, sprintMin = 0;

function setMode(m) {
  curMode = m;
  document.querySelectorAll('[id^="mode-"]').forEach(el => el.classList.remove('active'));
  document.getElementById('mode-' + m).classList.add('active');
}

function setProduct(p) {
  curProd = p;
  document.querySelectorAll('[id^="prod-"]').forEach(el => el.classList.remove('active'));
  document.getElementById('prod-' + p).classList.add('active');
  document.getElementById('prodBanner').textContent = PRODUCTS[p].emoji + ' ' + PRODUCTS[p].name;
  const el = document.getElementById('angulo');
  if (!el.dataset.edited) el.value = ANGLES[p] || '';
}

function setTab(t) {
  ['params','output','variantes'].forEach(x => {
    document.getElementById('panel-' + x).classList.add('hidden');
    document.getElementById('tab-' + x).classList.remove('active');
  });
  document.getElementById('panel-' + t).classList.remove('hidden');
  document.getElementById('tab-' + t).classList.add('active');
}

function updateFormula() {
  const v = document.getElementById('multiplier').value;
  document.getElementById('multVal').textContent = v;
  document.getElementById('fMult').textContent = v;
  document.getElementById('fTotal').textContent = v;
  document.getElementById('fDen').textContent = v;
}

async function generate() {
  if (!curProd) { alert('Elige un producto T1 en el sidebar primero.'); return; }
  const prod = PRODUCTS[curProd];
  const audiencia = document.getElementById('audiencia').value;
  const canal = document.getElementById('canal').value;
  const formato = document.getElementById('formato').value;
  const tono = document.getElementById('tono').value;
  const angulo = document.getElementById('angulo').value || 'Beneficio principal del producto';
  const mult = parseInt(document.getElementById('multiplier').value);

  const btn = document.getElementById('genBtn');
  const spin = document.getElementById('genSpin');
  const txt = document.getElementById('genTxt');
  btn.disabled = true; txt.textContent = 'Generando...'; spin.classList.remove('hidden');

  document.getElementById('outBody').innerHTML = '<span class="pulsing">Generando ' + mult + ' variantes para ' + prod.name + '...</span>';
  setTab('output');

  const sys = `Eres T1zima, agente de contenido de T1.\n${BRAND}\n\nContexto del producto:\n${prod.ctx}\n\nREGLAS ABSOLUTAS:\n1. NUNCA empieces con el nombre del producto — empieza con el dolor o el beneficio\n2. Cada variante tiene ángulo DISTINTO (no paráfrasis del mismo punto)\n3. Gancho: máximo 2 líneas, curiosidad o identificación inmediata\n4. Contenido 100% listo para publicar en el canal indicado\n5. Prompts visuales en inglés, cinematográficos y específicos\n6. Prompt de audio incluye: tono + pace + emoción + energía\n7. Responde SOLO JSON válido sin markdown ni texto extra`;

  const usr = `Genera ${mult} variantes para:\n- Producto: ${prod.name}\n- Canal: ${canal}\n- Formato: ${formato}\n- Audiencia: ${audiencia}\n- Tono: ${tono}\n- Ángulo base: ${angulo}\n\nJSON exacto sin markdown:\n{\n  "variantes": [\n    {\n      "id": 1,\n      "angulo": "nombre 3-5 palabras",\n      "gancho": "hook listo para usar",\n      "contenido": "contenido completo listo para publicar",\n      "prompt_visual": "prompt en inglés para Runway/Krea/Higgsfield",\n      "prompt_audio": "instrucción ElevenLabs: tono, pace, emoción",\n      "cta": "llamada a la acción"\n    }\n  ]\n}`;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: sys,
        messages: [{ role: 'user', content: usr }]
      })
    });
    const data = await res.json();
    const raw = data.content.filter(b => b.type === 'text').map(b => b.text).join('');
    const parsed = JSON.parse(raw.replace(/```json|```/g, '').trim());
    variants = parsed.variantes || [];
    sPiezas++; sVars += variants.length;
    updateMetrics();
    renderVariants();
    addHistory(angulo, canal, variants.length, prod.emoji);
    showVariant(0);
    setTab('output');
  } catch(e) {
    document.getElementById('outBody').textContent = 'Error al generar. Revisa tu API key y vuelve a intentar.\n\n' + e.message;
    setTab('output');
  }
  btn.disabled = false; txt.textContent = 'Generar de nuevo'; spin.classList.add('hidden');
}

function renderVariants() {
  document.getElementById('varCount').textContent = variants.length + ' variantes';
  document.getElementById('varGrid').innerHTML = variants.map((v,i) => `
    <div class="variant-card ${i===0?'selected':''}" onclick="showVariant(${i})">
      <div class="variant-label">Variante ${i+1} — ${v.angulo}</div>
      <div class="variant-hook">${v.gancho}</div>
      <div class="variant-sub">Visual: ${(v.prompt_visual||'').substring(0,70)}...</div>
    </div>`).join('');
}

function showVariant(i) {
  const v = variants[i]; if (!v) return;
  document.querySelectorAll('.variant-card').forEach((c,idx) => c.classList.toggle('selected', idx===i));
  document.getElementById('outLabel').textContent = `Variante ${i+1} / ${variants.length} — ${PRODUCTS[curProd]?.name || ''}`;
  document.getElementById('outBody').textContent =
    `🎯 ÁNGULO\n${v.angulo}\n\n` +
    `⚡ GANCHO\n${v.gancho}\n\n` +
    `📝 CONTENIDO\n${v.contenido}\n\n` +
    `🎬 PROMPT VISUAL (Runway / Krea / Higgsfield)\n${v.prompt_visual}\n\n` +
    `🎙 AUDIO (ElevenLabs)\n${v.prompt_audio}\n\n` +
    `→ CTA\n${v.cta}`;
}

function copyOut() {
  navigator.clipboard.writeText(document.getElementById('outBody').textContent);
  const b = event.target; b.textContent = '✓ Copiado'; setTimeout(()=>b.textContent='Copiar',1500);
}

function updateMetrics() {
  document.getElementById('mPiezas').textContent = sPiezas;
  document.getElementById('mVars').textContent = sVars;
  document.getElementById('bPiezas').style.width = Math.min(sPiezas*10,100)+'%';
  document.getElementById('bVars').style.width = Math.min(sVars*5,100)+'%';
  document.getElementById('benchPill').textContent = sVars + ' variantes generadas';
}

function addHistory(angulo, canal, count, emoji) {
  const now = new Date().toLocaleTimeString('es-MX',{hour:'2-digit',minute:'2-digit'});
  const html = `<div class="h-item"><div class="h-meta">${now} · ${emoji} · ${canal} · ${count} var.</div><div class="h-text">${angulo}</div></div>`;
  ['historyList','rpHist'].forEach(id => {
    const el = document.getElementById(id);
    if (el.querySelector('div[style]')) el.innerHTML = '';
    el.innerHTML = html + el.innerHTML;
  });
}

function toggleTimer() {
  if (timerOn) {
    clearInterval(timerIv); timerOn = false;
    document.getElementById('timerBtn').textContent = 'Continuar';
    document.getElementById('timerSub').textContent = 'Pausado';
  } else {
    timerOn = true;
    document.getElementById('timerBtn').textContent = 'Pausar';
    document.getElementById('timerSub').textContent = 'Sprint en progreso...';
    timerIv = setInterval(() => {
      timerSec--;
      sprintMin = Math.floor((1500 - timerSec) / 60);
      document.getElementById('mTime').textContent = sprintMin + ' min';
      document.getElementById('bTime').style.width = Math.min((sprintMin/25)*100,100)+'%';
      if (timerSec <= 0) {
        clearInterval(timerIv); timerOn = false;
        document.getElementById('timerBtn').textContent = 'Iniciar';
        document.getElementById('timerSub').textContent = '¡Sprint completado!';
        timerSec = 0;
      }
      const m = Math.floor(timerSec/60), s = timerSec%60;
      document.getElementById('timerNum').textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    }, 1000);
  }
}

function resetTimer() {
  clearInterval(timerIv); timerOn = false; timerSec = 1500;
  document.getElementById('timerNum').textContent = '25:00';
  document.getElementById('timerBtn').textContent = 'Iniciar';
  document.getElementById('timerSub').textContent = 'Jake Knapp — máximo foco';
}

document.getElementById('angulo').addEventListener('input', function() { this.dataset.edited = '1'; });
</script>
